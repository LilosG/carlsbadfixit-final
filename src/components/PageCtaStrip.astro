---
import { businessProfile } from "../data/site-config";

export interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow = "Get started",
  title = "Ready to check off your list?",
  body = "Share your project details, location, and photos for a clear, no-obligation estimate.",
  primaryHref = "/contact/",
  primaryLabel = "Request an estimate",
  secondaryHref = businessProfile.contact.phoneHref,
  secondaryLabel = `Call or text ${businessProfile.contact.phoneDisplay}`,
} = Astro.props;
---

<section
  class="relative overflow-hidden rounded-3xl border border-slate-200/80 bg-white px-5 py-7 shadow-[0_18px_42px_rgba(15,23,42,0.1)] md:px-8 md:py-9"
>
  <div
    aria-hidden="true"
    class="from-cf-primary/80 via-cf-warning/80 pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r to-sky-400/80"
  >
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
    <div class="max-w-3xl space-y-3">
      <p
        class="text-[11px] font-semibold tracking-[0.18em] text-slate-500 uppercase"
      >
        {eyebrow}
      </p>
      <h2 class="text-h2 text-cf-text md:text-h1 font-semibold tracking-tight">
        {title}
      </h2>
      <p class="text-cf-textMuted text-body-sm md:text-base">
        {body}
      </p>
    </div>

    <div
      class="grid w-full gap-2.5 rounded-2xl border border-slate-200 bg-slate-50/90 p-3 sm:min-w-[320px]"
    >
      <a href={primaryHref} class="btn-primary h-11 justify-center text-sm">
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="btn-pill-elevated h-11 justify-center text-sm"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
