---
import { footerSections } from "../data/navigation";
import { businessProfile } from "../data/site-config";
---

<footer class="border-cf-footerMuted bg-cf-footer text-cf-textMuted border-t">
  <div class="mx-auto max-w-6xl space-y-8 px-4 py-8">
    <div
      class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between"
    >
      <div class="space-y-4 md:max-w-sm">
        <div class="flex items-center gap-3">
          <div
            class="bg-cf-card flex h-14 w-14 items-center justify-center overflow-hidden rounded-full sm:h-16 sm:w-16"
          >
            <picture>
              <source
                srcset="
                  /images/logo/logo-small.webp 1x,
                  /images/logo/logo-medium.webp 2x,
                  /images/logo/logo-large.webp 3x
                "
                type="image/webp"
              />
              <source
                srcset="
                  /images/logo/logo-small.png 1x,
                  /images/logo/logo-medium.png 2x,
                  /images/logo/logo-large.png 3x
                "
                type="image/png"
              />
              <img
                src="/images/logo/logo-medium.png"
                alt={businessProfile.name}
                class="h-full w-full object-contain"
                loading="lazy"
              />
            </picture>
          </div>
          <div class="flex flex-col leading-tight">
            <a
              href="/"
              class="text-sm font-semibold tracking-tight text-white md:text-base"
            >
              {businessProfile.name}
            </a>
            <span class="text-cf-textMuted text-[11px] md:text-xs">
              {businessProfile.tagline}
            </span>
          </div>
        </div>
        <p class="text-cf-textMuted max-w-xs text-sm">
          Local handyman serving Carlsbad and nearby North County San Diego
          communities with small home repairs and improvements.
        </p>
        <p class="text-cf-textMuted text-xs">
          {businessProfile.address.streetAddress}, {
            businessProfile.address.addressLocality
          }, {businessProfile.address.addressRegion}
          {businessProfile.address.postalCode}
        </p>
      </div>

      <div
        class="flex flex-1 flex-wrap gap-8 md:gap-10 md:border-l md:border-white/5 md:pl-10"
      >
        {
          footerSections.map((section) => (
            <div class="space-y-2">
              <p class="text-cf-textMuted text-[11px] font-semibold tracking-wide uppercase">
                {section.title}
              </p>
              {section.links.map((link) => (
                <a
                  href={link.href}
                  class="text-cf-textMuted block text-[13px] underline-offset-4 hover:text-sky-300 hover:underline"
                >
                  {link.label}
                </a>
              ))}
            </div>
          ))
        }

        <div class="space-y-3">
          <p
            class="text-cf-textMuted text-[11px] font-semibold tracking-wide uppercase"
          >
            Contact
          </p>
          <div class="space-y-1 text-sm">
            <p class="text-cf-textMuted">Call or text:</p>
            <a
              href={businessProfile.contact.phoneHref}
              data-ga-call="true"
              data-ga-location="footer_call"
              data-ga-event="call_click"
              data-ga-label="site_phone"
              class="inline-flex items-center text-sm font-semibold text-sky-300 hover:text-sky-200"
            >
              {businessProfile.contact.phoneDisplay}
            </a>
          </div>
          <div class="space-y-1 text-sm">
            <p class="text-cf-textMuted">Email:</p>
            <a
              href={`mailto:${businessProfile.contact.email}`}
              class="inline-flex items-center text-sm font-medium text-sky-300 hover:text-sky-200"
            >
              {businessProfile.contact.email}
            </a>
          </div>
          <p class="text-cf-textMuted text-xs">
            Typical response during normal business hours.
          </p>
          <p class="text-cf-textMuted text-xs">
            Hours: {businessProfile.hours[0].dayOfWeek.slice(0, 3)}–{
              businessProfile.hours[
                businessProfile.hours.length - 1
              ].dayOfWeek.slice(0, 3)
            }, {businessProfile.hours[0].opens.slice(0, 2)}am–{
              businessProfile.hours[0].closes.slice(0, 2)
            }pm.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="border-cf-borderSoft/40 border-t">
    <div
      class="text-cf-textMuted mx-auto flex max-w-6xl justify-center px-4 py-4 text-xs"
    >
      <p class="text-center">
        © {new Date().getFullYear()}
        {businessProfile.name}. All rights reserved.
        <span class="text-cf-borderSoft mx-1.5">•</span>
        Website designed by
        <a
          href="https://lilosgrowth.com"
          class="text-cf-accentBlue hover:text-cf-accentBlue/80 font-medium"
          target="_blank"
          rel="noreferrer"
        >
          Lilos Growth
        </a>
      </p>
    </div>
  </div>
</footer>
