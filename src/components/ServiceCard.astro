---
interface Props {
  service: {
    slug: string;
    name: string;
    shortDescription: string;
  };
  primaryAreaSlug: string;
  primaryAreaName: string;
  variant?: "global" | "local";
}

const {
  service,
  primaryAreaSlug,
  primaryAreaName,
  variant = "global",
} = Astro.props;

const primaryServiceUrl =
  variant === "local"
    ? `/service-areas/${primaryAreaSlug}/${service.slug}/`
    : `/services/${service.slug}/`;
---

<article class="card-elevated group flex flex-col overflow-hidden">
  <div class="from-cf-accentBlue to-cf-primary -mx-6 -mt-6 mb-4 h-1 bg-gradient-to-r"></div>
  <div class="flex items-start justify-between gap-3">
    <h2 class="text-cf-text text-sm font-semibold">
      <a href={primaryServiceUrl} class="group-hover:text-cf-accentBlue transition-colors duration-150">
        {service.name}
      </a>
    </h2>
    <span
      class="from-cf-primary to-cf-warning inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br text-sm font-bold text-white shadow-md"
    >
      ✓
    </span>
  </div>
  <p class="text-body-sm mt-2 flex-1">
    {service.shortDescription}
  </p>
  <div class="mt-4 flex items-center gap-3 border-t border-slate-100 pt-3 text-xs">
    <a
      href={primaryServiceUrl}
      class="text-cf-accentBlue font-semibold underline-offset-2 hover:underline flex-1 min-w-0 truncate"
    >
      View {service.name.toLowerCase()} &rarr;
    </a>
    <a
      href={`/service-areas/${primaryAreaSlug}/${service.slug}/`}
      class="text-cf-textMuted underline-offset-2 hover:underline shrink-0"
    >
      In {primaryAreaName}
    </a>
  </div>
</article>
